# Snyk (https://snyk.io) policy file
version: v1.25.0

# Exclude developer CLI scripts from code analysis
# These are local tools that read/write files from user-provided paths by design
exclude:
  code:
    - scripts/generate-jwt.js
    - src/__tests__/**

# Ignore React Native upgrades
ignore:
  'npm:react-native':
    - '*':
        reason: React Native upgrades are managed manually
        expires: '2026-12-31T23:59:59.999Z'
  'npm:react-native@*':
    - '*':
        reason: React Native upgrades are managed manually
        expires: '2026-12-31T23:59:59.999Z'
  
  # Ignore Ruby dependencies in example app
  'rubygems:cocoapods':
    - '*':
        reason: Ruby dependencies in example app are not critical
        expires: '2026-12-31T23:59:59.999Z'
  'rubygems:xcodeproj':
    - '*':
        reason: Ruby dependencies in example app are not critical
        expires: '2026-12-31T23:59:59.999Z'
  'rubygems:activesupport':
    - '*':
        reason: Ruby dependencies in example app are not critical
        expires: '2026-12-31T23:59:59.999Z'

# Patch settings
patch: {}